#!/usr/bin/env python3
"""
CBSim Model Wrapper for RHEIA Integration

This module provides a wrapper for the CBSim thermal model to integrate
with the RHEIA optimization framework.
"""

import sys
import os
import time
import logging
import CoolProp.CoolProp as CP

# Add CBSim module path
cbsim_src_path = '/home/oxford/CBSim/src'
sys.path.insert(0, cbsim_src_path)

# Import CBSim model
try:
    import _module_carnot_battery as CB
except ImportError as e:
    print(f"Warning: Could not import CBSim module: {e}")
    print("Make sure the CBSim source code is available in the src directory")


class CBSimModel:
    """Wrapper class for CBSim thermal model"""

    def __init__(self):
        """Initialize the CBSim model wrapper"""
        self.model = None
        self.results = {}
        self.parameters = {}

        # Configure logging
        logging.basicConfig(
            level=logging.INFO,
            format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        )
        self.logger = logging.getLogger(__name__)

    def set_parameters(self, **kwargs):
        """
        Set model parameters with constraint checking

        Args:
            **kwargs: Model parameters
        """
        # 检查参数约束
        if not self._check_parameter_constraints(kwargs):
            self.logger.warning("Parameter constraints violated, using constrained values")
            kwargs = self._apply_parameter_constraints(kwargs)

        self.parameters.update(kwargs)

    def _check_parameter_constraints(self, parameters):
        """
        Check parameter constraints

        Args:
            parameters: Parameter dictionary

        Returns:
            bool: True if all constraints are satisfied
        """
        constraints = {
            # Design variables from literature (Table 1 and optimization settings)
            'dT_hp_cs_gl': (0.0, 100.0),          # ΔT_hs,gl: 0-100 K (heat source glide)
            'dT_hp_ev_sh': (3.0, 20.0),           # ΔT_hp,sh: 3-20 K (HP superheat)
            'dT_he_ev_sh': (3.0, 20.0),           # ΔT_orc,sh: 3-20 K (ORC superheat)
            'dT_hp_cd_sc': (3.0, 50.0),           # ΔT_hp,sc: 3-50 K (HP subcooling)
            'T_st_ht': (50.0, 150.0),             # t_st,ht: 50-150 °C (hot storage temperature)
            'dT_st_sp': (5.0, 100.0),             # ΔT_st,sp: 5-100 K (storage temperature spread)
            # Fixed temperature ranges (hard constraints)
            'T_hp_cs': (-25.0, 100.0),            # t_hs: -25 to 100 °C (heat source temperature)
            'T_he_cs': (-25.0, 50.0),             # t_cs: -25 to 50 °C (heat sink temperature)
            # Efficiency parameters (can be fixed or with small ranges)
            'eta_max_cp': (0.70, 0.80),           # η_is,comp: 0.70-0.80 (compressor isentropic efficiency)
            'eta_max_ex': (0.70, 0.80),           # η_is,exp: 0.70-0.80 (expander isentropic efficiency)
            'eta_pm': (0.45, 0.55),               # η_is,pmp: 0.45-0.55 (pump isentropic efficiency)
            # Pinch point temperatures (fixed at 3 K in literature, but keep range for flexibility)
            'dT_hp_ev_pp': (2.5, 3.5),            # ΔT_pp for HP evaporator: fixed around 3 K
            'dT_hp_cd_pp': (2.5, 3.5),            # ΔT_pp for HP condenser: fixed around 3 K
            'dT_he_ev_pp': (2.5, 3.5),            # ΔT_pp for ORC evaporator: fixed around 3 K
            'dT_he_cd_pp': (2.5, 3.5),            # ΔT_pp for ORC condenser: fixed around 3 K
            # Fluid indices (if using integer encoding for 34 fluids from Table 2)
            'fluid_hp_idx': (0, 33),              # Index for HP working fluid (0-33 mapping to CoolProp names)
            'fluid_he_idx': (0, 33)               # Index for ORC working fluid (0-33 mapping to CoolProp names)
        }

        for param, (min_val, max_val) in constraints.items():
            if param in parameters:
                value = parameters[param]
                if not (min_val <= value <= max_val):
                    self.logger.warning(f"Parameter {param}={value} violates constraint [{min_val}, {max_val}]")
                    return False

        # Additional coupled constraints
        # 1. t_st_lt = T_hp_cs - dT_hp_cs_gl ≥ -25°C (t_hs,min)
        if 'T_hp_cs' in parameters and 'dT_hp_cs_gl' in parameters:
            t_st_lt = parameters['T_hp_cs'] - parameters['dT_hp_cs_gl']
            if t_st_lt < -25.0:
                self.logger.warning(f"Coupled constraint violation: t_st_lt = {t_st_lt} < -25°C")
                return False

        # 2. t_st_lt = T_hp_cs - dT_hp_cs_gl ≥ T_st_ht - dT_st_sp (storage temperature consistency)
        if all(key in parameters for key in ['T_hp_cs', 'dT_hp_cs_gl', 'T_st_ht', 'dT_st_sp']):
            t_st_lt = parameters['T_hp_cs'] - parameters['dT_hp_cs_gl']
            t_st_ht = parameters['T_st_ht']
            dT_st_sp = parameters['dT_st_sp']
            if t_st_lt > t_st_ht - dT_st_sp:
                self.logger.warning(f"Coupled constraint violation: t_st_lt = {t_st_lt} > t_st_ht - dT_st_sp = {t_st_ht - dT_st_sp}")
                return False

        # 3. Minimum HP temperature rise: ΔT_hp_min = T_st_ht - (T_hp_cs - dT_hp_cs_gl) ≥ 5 K
        if all(key in parameters for key in ['T_st_ht', 'T_hp_cs', 'dT_hp_cs_gl']):
            delta_T_hp = parameters['T_st_ht'] - (parameters['T_hp_cs'] - parameters['dT_hp_cs_gl'])
            if delta_T_hp < 5.0:
                self.logger.warning(f"Coupled constraint violation: ΔT_hp = {delta_T_hp} < 5 K")
                return False

        # 4. Minimum ORC temperature drop: ΔT_orc_min = (T_st_ht - dT_st_sp) - T_he_cs ≥ 5 K
        if all(key in parameters for key in ['T_st_ht', 'dT_st_sp', 'T_he_cs']):
            delta_T_orc = (parameters['T_st_ht'] - parameters['dT_st_sp']) - parameters['T_he_cs']
            if delta_T_orc < 5.0:
                self.logger.warning(f"Coupled constraint violation: ΔT_orc = {delta_T_orc} < 5 K")
                return False

        return True

    def _apply_parameter_constraints(self, parameters):
        """
        Apply parameter constraints by clamping values

        Args:
            parameters: Parameter dictionary

        Returns:
            dict: Constrained parameters
        """
        constraints = {
            # Design variables from literature (Table 1 and optimization settings)
            'dT_hp_cs_gl': (0.0, 100.0),          # ΔT_hs,gl: 0-100 K (heat source glide)
            'dT_hp_ev_sh': (3.0, 20.0),           # ΔT_hp,sh: 3-20 K (HP superheat)
            'dT_he_ev_sh': (3.0, 20.0),           # ΔT_orc,sh: 3-20 K (ORC superheat)
            'dT_hp_cd_sc': (3.0, 50.0),           # ΔT_hp,sc: 3-50 K (HP subcooling)
            'T_st_ht': (50.0, 150.0),             # t_st,ht: 50-150 °C (hot storage temperature)
            'dT_st_sp': (5.0, 100.0),             # ΔT_st,sp: 5-100 K (storage temperature spread)
            # Fixed temperature ranges (hard constraints)
            'T_hp_cs': (-25.0, 100.0),            # t_hs: -25 to 100 °C (heat source temperature)
            'T_he_cs': (-25.0, 50.0),             # t_cs: -25 to 50 °C (heat sink temperature)
            # Efficiency parameters (can be fixed or with small ranges)
            'eta_max_cp': (0.70, 0.80),           # η_is,comp: 0.70-0.80 (compressor isentropic efficiency)
            'eta_max_ex': (0.70, 0.80),           # η_is,exp: 0.70-0.80 (expander isentropic efficiency)
            'eta_pm': (0.45, 0.55),               # η_is,pmp: 0.45-0.55 (pump isentropic efficiency)
            # Pinch point temperatures (fixed at 3 K in literature, but keep range for flexibility)
            'dT_hp_ev_pp': (2.5, 3.5),            # ΔT_pp for HP evaporator: fixed around 3 K
            'dT_hp_cd_pp': (2.5, 3.5),            # ΔT_pp for HP condenser: fixed around 3 K
            'dT_he_ev_pp': (2.5, 3.5),            # ΔT_pp for ORC evaporator: fixed around 3 K
            'dT_he_cd_pp': (2.5, 3.5),            # ΔT_pp for ORC condenser: fixed around 3 K
            # Fluid indices (if using integer encoding for 34 fluids from Table 2)
            'fluid_hp_idx': (0, 33),              # Index for HP working fluid (0-33 mapping to CoolProp names)
            'fluid_he_idx': (0, 33)               # Index for ORC working fluid (0-33 mapping to CoolProp names)
        }

        constrained_params = parameters.copy()
        for param, (min_val, max_val) in constraints.items():
            if param in constrained_params:
                value = constrained_params[param]
                if value < min_val:
                    constrained_params[param] = min_val
                elif value > max_val:
                    constrained_params[param] = max_val

        # Apply coupled constraints by adjusting related parameters
        # 1. Ensure t_st_lt = T_hp_cs - dT_hp_cs_gl ≥ -25°C (t_hs,min)
        if 'T_hp_cs' in constrained_params and 'dT_hp_cs_gl' in constrained_params:
            t_st_lt = constrained_params['T_hp_cs'] - constrained_params['dT_hp_cs_gl']
            if t_st_lt < -25.0:
                # Adjust dT_hp_cs_gl to satisfy constraint (reduce glide)
                constrained_params['dT_hp_cs_gl'] = constrained_params['T_hp_cs'] + 25.0
                # Clamp again to ensure within bounds
                if constrained_params['dT_hp_cs_gl'] < 0.0:
                    constrained_params['dT_hp_cs_gl'] = 0.0
                if constrained_params['dT_hp_cs_gl'] > 100.0:
                    # If still violated, adjust T_hp_cs (increase source temperature)
                    constrained_params['T_hp_cs'] = constrained_params['dT_hp_cs_gl'] - 25.0
                    # Clamp T_hp_cs to its bounds
                    if constrained_params['T_hp_cs'] < -25.0:
                        constrained_params['T_hp_cs'] = -25.0
                    if constrained_params['T_hp_cs'] > 100.0:
                        constrained_params['T_hp_cs'] = 100.0

        # 2. Ensure storage temperature consistency: t_st_lt ≤ t_st_ht - dT_st_sp
        if all(key in constrained_params for key in ['T_hp_cs', 'dT_hp_cs_gl', 'T_st_ht', 'dT_st_sp']):
            t_st_lt = constrained_params['T_hp_cs'] - constrained_params['dT_hp_cs_gl']
            t_st_ht = constrained_params['T_st_ht']
            dT_st_sp = constrained_params['dT_st_sp']
            if t_st_lt > t_st_ht - dT_st_sp:
                # Adjust dT_st_sp to satisfy constraint (increase spread)
                constrained_params['dT_st_sp'] = t_st_ht - t_st_lt
                # Clamp to bounds
                if constrained_params['dT_st_sp'] < 5.0:
                    constrained_params['dT_st_sp'] = 5.0
                if constrained_params['dT_st_sp'] > 100.0:
                    constrained_params['dT_st_sp'] = 100.0

        # 3. Ensure minimum HP temperature rise: ΔT_hp_min = T_st_ht - (T_hp_cs - dT_hp_cs_gl) ≥ 5 K
        if all(key in constrained_params for key in ['T_st_ht', 'T_hp_cs', 'dT_hp_cs_gl']):
            delta_T_hp = constrained_params['T_st_ht'] - (constrained_params['T_hp_cs'] - constrained_params['dT_hp_cs_gl'])
            if delta_T_hp < 5.0:
                # Adjust T_st_ht upward to satisfy constraint
                constrained_params['T_st_ht'] = (constrained_params['T_hp_cs'] - constrained_params['dT_hp_cs_gl']) + 5.0
                # Clamp to bounds
                if constrained_params['T_st_ht'] < 50.0:
                    constrained_params['T_st_ht'] = 50.0
                if constrained_params['T_st_ht'] > 150.0:
                    constrained_params['T_st_ht'] = 150.0

        # 4. Ensure minimum ORC temperature drop: ΔT_orc_min = (T_st_ht - dT_st_sp) - T_he_cs ≥ 5 K
        if all(key in constrained_params for key in ['T_st_ht', 'dT_st_sp', 'T_he_cs']):
            delta_T_orc = (constrained_params['T_st_ht'] - constrained_params['dT_st_sp']) - constrained_params['T_he_cs']
            if delta_T_orc < 5.0:
                # Adjust T_he_cs downward to satisfy constraint
                constrained_params['T_he_cs'] = (constrained_params['T_st_ht'] - constrained_params['dT_st_sp']) - 5.0
                # Clamp to bounds
                if constrained_params['T_he_cs'] < -25.0:
                    constrained_params['T_he_cs'] = -25.0
                if constrained_params['T_he_cs'] > 50.0:
                    constrained_params['T_he_cs'] = 50.0

        return constrained_params

    def evaluate(self):
        """
        Run CBSim evaluation with constraint violation tracking

        Returns:
            dict: Evaluation results including constraint violations
        """
        try:
            start_time = time.time()

            # Build complete parameter dictionary
            inputs = self._build_inputs()

            # 准备热泵输入
            p_hp_cs_su = 1e+5
            T_hp_cs_su = inputs['T_hp_cs'] + 273.15
            T_hp_cs_ex = T_hp_cs_su - inputs['dT_hp_cs_gl']
            m_hp_cs = 1.0
            i_hp_cs_su = CP.PropsSI('H', 'T', T_hp_cs_su, 'P', p_hp_cs_su, inputs['fluid_hp_cs'])
            i_hp_cs_ex = CP.PropsSI('H', 'T', T_hp_cs_ex, 'P', p_hp_cs_su, inputs['fluid_hp_cs'])
            P_hp = 1e+3

            # 准备热机输入
            p_he_cs_su = 1e+5
            T_he_cs_su = inputs['T_he_cs'] + 273.15
            T_he_cs_ex = T_he_cs_su + inputs['dT_he_cs_gl']
            m_he_cs = 1.0
            i_he_cs_su = CP.PropsSI('H', 'T', T_he_cs_su, 'P', p_he_cs_su, inputs['fluid_he_cs'])
            i_he_cs_ex = CP.PropsSI('H', 'T', T_he_cs_ex, 'P', p_he_cs_su, inputs['fluid_he_cs'])
            P_he = 1e+3

            T_st_ht_k = inputs['T_st_ht'] + 273.15

            # 完整参数字典
            dp_hp_ev = 0.00e+5
            dp_hp_cd = 0.00e+5
            dp_he_ev = 0.00e+5
            dp_he_cd = 0.00e+5
            epsilon = 0.80

            my_CB_params = {
                'p_hp_cs_su': p_hp_cs_su,
                'i_hp_cs_su': i_hp_cs_su,
                'i_hp_cs_ex': i_hp_cs_ex,
                'p_he_cs_su': p_he_cs_su,
                'i_he_cs_su': i_he_cs_su,
                'i_he_cs_ex': i_he_cs_ex,
                'm_hp_cs': m_hp_cs,
                'm_he_cs': m_he_cs,
                'p_st_ht': 7.5e+5,  # Storage pressure fixed at 7.5 bar (750 kPa)
                'p_st_lt': 7.5e+5,  # Same for low-temperature side
                'T_st_ht': T_st_ht_k,
                'dT_st_sp': inputs['dT_st_sp'],
                'eta_max_cp': inputs['eta_max_cp'],
                'eta_max_ex': inputs['eta_max_ex'],
                'eta_pm': inputs['eta_pm'],
                'dT_hp_ev_pp': inputs['dT_hp_ev_pp'],
                'dT_hp_cd_pp': inputs['dT_hp_cd_pp'],
                'dT_he_ev_pp': inputs['dT_he_ev_pp'],
                'dT_he_cd_pp': inputs['dT_he_cd_pp'],
                'dT_he_ev_sh': inputs['dT_he_ev_sh'],
                'dT_hp_ev_sh': inputs['dT_hp_ev_sh'],
                'dT_he_cd_sc': inputs['dT_he_cd_sc'],
                'dT_hp_cd_sc': inputs['dT_hp_cd_sc'],
                'dp_hp_ev': dp_hp_ev,
                'dp_hp_cd': dp_hp_cd,
                'dp_hp_rg_lq': (dp_hp_ev+dp_hp_cd)/2,
                'dp_hp_rg_vp': (dp_hp_ev+dp_hp_cd)/2,
                'epsilon_hp': epsilon,
                'dp_he_ev': dp_he_ev,
                'dp_he_cd': dp_he_cd,
                'dp_he_rg_lq': (dp_he_ev+dp_he_cd)/2,
                'dp_he_rg_vp': (dp_he_ev+dp_he_cd)/2,
                'epsilon_he': epsilon,
                'm_hp_st_max': 0e+0,
                'm_he_st_max': 0e+0,
                'version': inputs['version'],
                'mode_hp': True,
                'mode_he': True,
                'mode': 'source',
                'p_ref': p_he_cs_su,
                'T_ref': T_he_cs_su,
                'p_0': p_he_cs_su,
                'T_0': T_he_cs_su,
                'fluid_hp': inputs['fluid_hp'],
                'fluid_he': inputs['fluid_he'],
                'fluid_st': inputs['fluid_st'],
                'wet_ex': 0,
                'm_rat_hp': 0,
                'm_rat_he': 0,
            }

            # 准备选项
            print_flag, plot_flag = False, False
            debug = False
            exergy = True
            options = {'plot_flag': plot_flag,
                       'print_flag': print_flag,
                       'debug': debug,
                       'exergy': exergy}

            # 准备输入元组
            input_tuple = (p_hp_cs_su, i_hp_cs_su, p_hp_cs_su, i_hp_cs_ex, m_hp_cs, inputs['fluid_hp_cs'],
                          p_he_cs_su, i_he_cs_su, p_he_cs_su, i_he_cs_ex, m_he_cs, inputs['fluid_he_cs'],
                          P_hp, P_he)

            # 运行仿真
            self.model = CB.SRVCHP_SRORC_STES2T(input_tuple, my_CB_params, options)
            self.model.evaluate()

            # Extract performance metrics
            self.results = self._extract_results(start_time)

            self.logger.info(f"Evaluation successful - CB efficiency: {self.results['cb_efficiency']:.4f}")
            return True

        except Exception as e:
            self.logger.error(f"Evaluation failed: {e}")
            self.results = self._build_failure_results(e, start_time)
            return False

    def _build_inputs(self):
        """Build complete input dictionary from parameters"""
        # Fluid list from literature Table 2 (34 fluids)
        # Placeholder list - should be replaced with actual 34 fluids from Table 2
        fluid_list = [
            'R1233zd(E)', 'R227ea', 'R1234ze(Z)', 'R1234yf', 'R134a',
            'R152a', 'R245fa', 'R290', 'R600', 'R600a',
            'R601', 'R601a', 'R123', 'R124', 'R125',
            'R143a', 'R218', 'R236fa', 'R245ca', 'R32',
            'R41', 'R407C', 'R410A', 'R507A', 'R717',
            'R744', 'R718', 'R729', 'R764', 'R1150',
            'R1270', 'R1311', 'R141b', 'R1132a'  # 34 fluids total
        ]

        # Get fluid indices and map to CoolProp names
        fluid_hp_idx = int(self.parameters.get('fluid_hp_idx', 0))
        fluid_he_idx = int(self.parameters.get('fluid_he_idx', 1))
        fluid_hp = fluid_list[fluid_hp_idx % len(fluid_list)]
        fluid_he = fluid_list[fluid_he_idx % len(fluid_list)]

        inputs = {
